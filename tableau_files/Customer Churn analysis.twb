    <dashboard name='Customer Churn Analysis' type='storyboard'>
      <style>
        <style-rule element='story-point-caption'>
          <format attr='width' value='280' />
        </style-rule>
      </style>
      <size sizing-mode='automatic' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='97978' id='1' param='vert' removable='false' type-v2='layout-flow' w='98730' x='635' y='1011'>
            <zone h='4172' id='3' type-v2='title' w='98730' x='635' y='1011' />
            <zone fixed-size='113' h='14286' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='98730' x='635' y='5183' />
            <zone h='79520' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='98730' x='635' y='19469'>
              <flipboard active-id='1' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='Overall churn at ~28%, with  higher churn observed among newer customers and those on month-to-month contracts.' captured-sheet='Executive Overview' id='1' />
                  <story-point caption='Churn is concentrated among customers with fiber optic services, electronic check payments, paperless Billing and lack of device protection' captured-sheet='Churning by features' id='2' />
                  <story-point caption='Churn is concentrated among customers with lack of security/support and also who doesn&apos;t opt in streaming movies/TV.' captured-sheet='Churning by features -2' id='5' />
                  <story-point caption='Customers with low tenure and higher monthly charges exhibit the highest churn risk, especially under flexible contract types.' captured-sheet='Churn Risk &amp; Behaviour' id='3'>
                    <capturedDeltas>
                      <worksheet name='Churn rate by Internet &amp; Contract'>
                        <filter class='categorical' column='[federated.1sfbfk21dxsako140eaa41tkw2fk].[Action (Tenure-Group,Charges category)]'>
                          <groupfilter function='crossjoin' user:ui-enumeration='all' user:ui-marker='enumerate'>
                            <groupfilter function='level-members' level='[Calculation_1644508504870919]' />
                            <groupfilter function='level-members' level='[Calculation_1644508560416778]' />
                          </groupfilter>
                        </filter>
                      </worksheet>
                    </capturedDeltas>
                  </story-point>
                  <story-point caption='While most churn comes from low-value customers, a critical segment of high-value customers is being lost, driving significant revenue at risk.' captured-sheet='Customer Retention &amp; Revenue Risk Analysis' id='4'>
                    <capturedDeltas>
                      <datasource name='Parameters'>
                        <column name='[Parameter 1]' value='&quot;Contract&quot;' />
                      </datasource>
                    </capturedDeltas>
                  </story-point>
                </story-points>
              </flipboard>
            </zone>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
          </zone-style>
        </zone>
      </zones>
      <simple-id uuid='{3DF12077-964D-41E0-9FCB-65567F1FC39B}' />
    </dashboard>
