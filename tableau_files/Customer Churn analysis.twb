            <column caption='Tenure-Corrected' datatype='real' name='[Calculation_1644508504621062]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='ABS([tenure])' />
            </column>
            <column caption='Tenure-Group' datatype='string' name='[Calculation_1644508504870919]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_1644508504621062] &lt;12 THEN &apos;0-1 Year&apos;&#10;ELSEIF [Calculation_1644508504621062] &lt;24 THEN &apos;1-2 Year&apos;&#10;ELSE &apos;2+ Year&apos;&#10;END' />
            </column>
            <column caption='Charges category' datatype='string' name='[Calculation_1644508560416778]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_1644508488818690] &lt; 50 THEN &apos;Low&apos;&#10;ELSEIF [Calculation_1644508488818690] &lt; 100 THEN &apos;Medium&apos;&#10;ELSE &apos;High&apos;&#10;END' />
            </column>
            <column caption='Risk segment' datatype='string' name='[Calculation_1644508572073995]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_1644508504621062]&lt;12 AND [Calculation_1644508488818690]&gt;100 THEN &apos;High Risk&apos;&#10;ELSEIF [Calculation_1644508504621062]&lt;12 AND ([Calculation_1644508488818690]&gt;50 OR [Calculation_1644508488818690]&lt;100)  THEN &apos;Medium Risk&apos;&#10;ELSE &apos;Low Risk&apos;&#10;END' />
            </column>
            <column datatype='string' name='[Churn (group)]' role='dimension' type='nominal'>
              <calculation class='categorical-bin' column='[Churn]' new-bin='true'>
                <bin default-name='false' value='&quot;No&quot;'>
                  <value>&quot;no&quot;</value>
                  <value>&quot;No&quot;</value>
                  <value>&quot;NO&quot;</value>
                </bin>
                <bin default-name='false' value='&quot;Yes&quot;'>
                  <value>&quot;yes&quot;</value>
                  <value>&quot;Yes&quot;</value>
                  <value>&quot;YES&quot;</value>
                </bin>
              </calculation>
            </column>
            <column datatype='string' name='[Churn]' role='dimension' type='nominal' />
            <column caption='Monthly Charges' datatype='string' name='[MonthlyCharges]' role='dimension' type='nominal' />
