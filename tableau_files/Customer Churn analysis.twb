      <aliases enabled='yes' />
      <column caption='Senior Citizen-Corrected' datatype='string' name='[Calculation_1644508487770112]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [SeniorCitizen]=1 THEN &apos;Yes&apos;&#10;ELSE &apos;No&apos;&#10;END' />
      </column>
      <column caption='Monthly Charges-Corrected' datatype='real' name='[Calculation_1644508488818690]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='FLOAT(REGEXP_REPLACE([MonthlyCharges],&apos;[^0-9.]&apos;,&apos;&apos;))' />
      </column>
      <column caption='Total Charges-Corrected' datatype='real' name='[Calculation_1644508496928771]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='FLOAT(REGEXP_REPLACE([TotalCharges],&apos;[^0-9.]&apos;,&apos;&apos;))' />
      </column>
      <column caption='Tenure-Corrected' datatype='real' name='[Calculation_1644508504621062]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ABS([tenure])' />
      </column>
      <column caption='Tenure-Group' datatype='string' name='[Calculation_1644508504870919]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1644508504621062] &lt;12 THEN &apos;0-1 Year&apos;&#10;ELSEIF [Calculation_1644508504621062] &lt;24 THEN &apos;1-2 Year&apos;&#10;ELSE &apos;2+ Year&apos;&#10;END' />
      </column>
      <column caption='Churned Customers' datatype='integer' name='[Calculation_1644508510318600]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Churn (group)]=&apos;Yes&apos; THEN 1 ELSE 0 END)' />
      </column>
      <column caption='Churn Rate' datatype='real' name='[Calculation_1644508511014921]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Churn (group)]=&apos;Yes&apos; THEN 1 ELSE 0 END)/COUNT([__tableau_internal_object_id__].[customer_churn.csv_B3CE888078E044CAA3C87E638C1FF687]) *100' />
      </column>
      <column caption='Charges category' datatype='string' name='[Calculation_1644508560416778]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1644508488818690] &lt; 50 THEN &apos;Low&apos;&#10;ELSEIF [Calculation_1644508488818690] &lt; 100 THEN &apos;Medium&apos;&#10;ELSE &apos;High&apos;&#10;END' />
      </column>
      <column caption='Risk segment' datatype='string' name='[Calculation_1644508572073995]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1644508504621062]&lt;12 AND [Calculation_1644508488818690]&gt;100 THEN &apos;High Risk&apos;&#10;ELSEIF [Calculation_1644508504621062]&lt;12 AND ([Calculation_1644508488818690]&gt;50 OR [Calculation_1644508488818690]&lt;100)  THEN &apos;Medium Risk&apos;&#10;ELSE &apos;Low Risk&apos;&#10;END' />
      </column>
      <column caption='Category selector' datatype='string' name='[Calculation_1644508580372492]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 1]= &apos;Contract&apos; THEN [Contract]&#10;ELSEIF [Parameters].[Parameter 1]=&apos;Device Protection&apos; THEN [DeviceProtection]&#10;ELSEIF [Parameters].[Parameter 1]= &apos;Internet Service&apos; THEN [InternetService]&#10;ELSEIF [Parameters].[Parameter 1]= &apos;Online Backup&apos; THEN [OnlineBackup]&#10;ELSEIF [Parameters].[Parameter 1]= &apos;Online Security&apos; THEN [OnlineSecurity]&#10;ELSEIF [Parameters].[Parameter 1]= &apos;Paperless Billing&apos; THEN [PaperlessBilling]&#10;ELSEIF [Parameters].[Parameter 1]= &apos;Payment Method (group)&apos; THEN [Payment Method (group)]&#10;ELSEIF [Parameters].[Parameter 1]= &apos;Phone Service&apos; THEN [PhoneService]&#10;ELSEIF [Parameters].[Parameter 1]= &apos;Streaming Movies&apos; THEN [StreamingMovies]&#10;ELSEIF [Parameters].[Parameter 1]=&apos;Streaming TV&apos; THEN [StreamingTV]&#10;ELSEIF [Parameters].[Parameter 1]= &apos;Tenure-Group&apos; THEN [Calculation_1644508504870919]&#10;ELSEIF [Parameters].[Parameter 1]= &apos;Tech Support&apos; THEN [TechSupport]&#10;END' />
      </column>
      <column caption='CLV' datatype='real' name='[Calculation_1644508672397325]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1644508504621062]*[Calculation_1644508488818690]' />
      </column>
      <column caption='Priority Segment' datatype='string' name='[Calculation_1644508674224142]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Churn (group)]=&apos;Yes&apos; AND [Calculation_1644508672397325]&gt;3662 THEN &apos;High-val Customers - Lost&apos;&#10;ELSEIF [Churn (group)]=&apos;Yes&apos; AND [Calculation_1644508672397325]&gt;1379 THEN &apos;Medium-val Customers - Lost&apos;&#10;ELSEIF [Churn (group)]=&apos;Yes&apos; THEN &apos;Low-val Customers - Lost&apos;&#10;&#10;ELSEIF [Calculation_1644508672397325]&gt;3662 THEN &apos;High-val Customers - Active&apos;&#10;ELSEIF [Calculation_1644508672397325]&gt;1379 THEN &apos;Medium-val Customers - Active&apos;&#10;ELSE &apos;Low-val Customers - Active&apos;&#10;&#10;END' />
